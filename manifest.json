{
  "manifest_version": 2,
  "name": "PriceComparison",
  "version": "2.0.0",
  "description": "Live price comparison tool for bike parts",
  "permissions": [
    "activeTab",
    "storage",
    "https://*.amazon.com/*",
    "https://*.ebay.com/*",
    "https://*.cykelgear.dk/*",
    "https://*.bike-discount.de/*",
    "https://*.bikable.no/*",
    "https://*.bikable.com/*",
    "https://*.bikable.se/*",
    "https://*.bike-components.de/*",
    "https://jrgrafisk.dk/*",
    "https://*.allbike.dk/*",
    "https://*.cykelpartner.dk/*",
    "https://*.r2-bike.com/*",
    "https://*.cykelexperten.dk/*",
    "https://*.fribikeshop.dk/*",
    "https://*.alltricks.com/*",
    "https://*.cykelshoppen.dk/*"
  ],
  "background": {
    "scripts": ["config.js", "background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.com/*",
        "*://*.ebay.com/*",
        "*://*.cykelgear.dk/*",
        "*://*.bike-discount.de/*",
        "*://*.bikable.no/*",
        "*://*.bikable.com/*",
        "*://*.bikable.se/*",
        "*://*.bike-components.de/*",
        "*://jrgrafisk.dk/*",
        "*://*.allbike.dk/*",
        "*://*.cykelpartner.dk/*",
        "*://*.r2-bike.com/*",
        "*://*.cykelexperten.dk/*",
        "*://*.fribikeshop.dk/*",
        "*://*.alltricks.com/*",
        "*://*.cykelshoppen.dk/*"
      ],
      "js": ["config.js", "content.js"]
    }
  ],
  "browser_action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/16x16pp.png",
    "48": "icons/48x48pp.png",
    "128": "icons/128x128pp.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "firefoxextension@jrgrafisk.dk",
      "strict_min_version": "134.0"
    }
  }
}