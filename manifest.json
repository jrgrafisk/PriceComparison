{
  "manifest_version": 3,
  "name": "PriceComparison",
  "version": "2.0.0",
  "description": "Live price comparison tool for bike parts",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "*://*.amazon.com/*",
    "*://*.ebay.com/*",
    "*://*.cykelgear.dk/*",
    "*://*.bike-discount.de/*",
    "*://*.bikable.no/*",
    "*://*.bikable.com/*",
    "*://*.bikable.se/*",
    "*://*.bike-components.de/*",
    "*://jrgrafisk.dk/*",
    "*://*.allbike.dk/*",
    "*://*.cykelpartner.dk/*",
    "*://*.r2-bike.com/*",
    "*://*.cykelexperten.dk/*",
    "*://*.fribikeshop.dk/*",
    "*://*.alltricks.com/*",
    "*://*.cykelshoppen.dk/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.com/*",
        "*://*.ebay.com/*",
        "*://*.cykelgear.dk/*",
        "*://*.bike-discount.de/*",
        "*://*.bikable.no/*",
        "*://*.bikable.com/*",
        "*://*.bikable.se/*",
        "*://*.bike-components.de/*",
        "*://jrgrafisk.dk/*",
        "*://*.allbike.dk/*",
        "*://*.cykelpartner.dk/*",
        "*://*.r2-bike.com/*",
        "*://*.cykelexperten.dk/*",
        "*://*.fribikeshop.dk/*",
        "*://*.alltricks.com/*",
        "*://*.cykelshoppen.dk/*"
      ],
      "js": ["config.js", "content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}