{
  "manifest_version": 2,
  "name": "PedalPricer",
  "version": "1.9.0",
  "description": "Compare bike part prices across multiple stores.",
  "permissions": [
    "activeTab",
    "storage",
    "https://*.cykelgear.dk/*",
    "https://*.bike24.com/*",
    "https://*.bike-discount.de/*",
    "https://*.bikable.no/*",
    "https://*.bikable.com/*",
    "https://*.bikable.se/*",
    "https://*.bike-components.de/*",
    "https://jrgrafisk.dk/*",
    "https://*.allbike.dk/*",
    "https://*.cykelpartner.dk/*",
	"https://*.r2-bike.com/*",
	"https://*.cykelexperten.dk/*",
	"https://*.fribikeshop.dk/*",
	"https://*.alltricks.com/*",
    "https://*.cykelshoppen.dk/*",
    "https://*.boerkopcykler.dk/*"
  ],
  "background": {
    "scripts": [
      "config.js",
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["config.js", "content.js"]
    }
  ],
  "icons": {
    "16": "icons/16x16pp.png",
    "48": "icons/48x48pp.png",
    "128": "icons/128x128pp.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "firefoxextension@jrgrafisk.dk",
      "strict_min_version": "134.0"
    }
  },
  "browser_action": {
    "default_popup": "popup.html"
  }
  }


